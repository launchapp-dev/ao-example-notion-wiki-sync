# Notion Wiki Sync — Environment Variables

# Notion integration token (required)
# Get it from: https://www.notion.so/my-integrations → New integration → copy the token
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Absolute path to the codebase for code cross-referencing (optional)
# If set, overrides config/wiki-config.yaml repository.path
REPO_PATH=/path/to/your/codebase
